# ============================================
# AI Career Launchpad — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ─── NVIDIA NIM API ──────────────────────────────────────────
# Get your free API key at: https://build.nvidia.com
# 1. Create account → 2. Click any model → 3. "Get API Key"
NVIDIA_API_KEY=nvapi-your-key-here

# Base URL for NVIDIA's hosted API catalog (default works for most users)
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model to use (browse models at https://build.nvidia.com)
# Recommended options:
#   meta/llama-3.3-70b-instruct    — Best quality (default)
#   meta/llama-3.1-8b-instruct     — Faster, lighter
#   nvidia/nemotron-3-super-120b-a12b — NVIDIA's own model
#   mistralai/mistral-large-latest  — Strong alternative
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ─── Adzuna API (for live job postings) ──────────────────────
# Free tier: 250 requests/month
# Sign up at: https://developer.adzuna.com
ADZUNA_APP_ID=your-app-id-here
ADZUNA_APP_KEY=your-app-key-here

# ─── Server Configuration ────────────────────────────────────
PORT=3001
RAG_SERVICE_URL=http://localhost:8000
NODE_ENV=development
